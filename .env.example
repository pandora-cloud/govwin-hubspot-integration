# GovWin-HubSpot Integration - Local Environment Variables
# Copy to .env and fill in real values: cp .env.example .env
# .env is gitignored and will never be committed.

###############################################################################
# GovWin Credentials (for validate.py and dry_run.py)
###############################################################################
GOVWIN_CLIENT_ID=your-govwin-client-id
GOVWIN_CLIENT_SECRET=your-govwin-client-secret
GOVWIN_USERNAME=your-govwin-email@company.com
GOVWIN_PASSWORD=your-govwin-password

###############################################################################
# HubSpot Credentials (for validate.py)
###############################################################################
HUBSPOT_PRIVATE_APP_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

###############################################################################
# Sync Configuration
###############################################################################
# GOVWIN_MARKED_VERSION=2.2        # "2.2" (Web Services), "2" (Deltek CRM), "" (all)
# GOVWIN_OPP_TYPES=ALL             # OPP, BID, TNS, FBO, OPN, TOP, ALL
# GOVWIN_MARKET=                   # Federal, SLED, or empty for both
# BATCH_SIZE=10                    # Opportunities per batch (max 25)
# LOG_LEVEL=INFO                   # DEBUG for verbose logging

###############################################################################
# AWS / LocalStack Configuration
###############################################################################
AWS_REGION=us-east-1

# Uncomment for LocalStack (docker-compose):
# AWS_ENDPOINT_URL=http://localhost:4566
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test
# SYNC_STATE_TABLE=govwin-hubspot-dev-sync-state
# ENTITY_MAPPINGS_TABLE=govwin-hubspot-dev-entity-mappings
# GOVWIN_SECRET_NAME=govwin-hubspot-dev/govwin
# HUBSPOT_SECRET_NAME=govwin-hubspot-dev/hubspot
# GOVWIN_TOKENS_SECRET_NAME=govwin-hubspot-dev/govwin-tokens
