# Top-most EditorConfig file for the project.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4
max_line_length = 100

[*.{tf,tfvars,hcl}]
indent_size = 2

[*.{json,yml,yaml,md,toml}]
indent_size = 2

[Makefile]
indent_style = tab
