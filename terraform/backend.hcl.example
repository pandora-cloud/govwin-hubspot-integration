# Terraform S3 backend configuration with native state locking.
# Copy to backend.hcl and fill in your values.
# Usage: terraform init -backend-config=backend.hcl
#
# Prerequisites:
#   - S3 bucket with versioning enabled
#   - Terraform >= 1.11
#
# The bucket must have versioning enabled for native S3 locking to work.
# No DynamoDB table is needed — locking uses S3 conditional writes.

bucket       = "your-terraform-state-bucket"
key          = "govwin-hubspot/terraform.tfstate"
region       = "us-east-1"
encrypt      = true
use_lockfile = true
