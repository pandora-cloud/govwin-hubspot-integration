# GovWin-HubSpot Integration - Terraform Configuration
# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored and will never be committed.

###############################################################################
# Required - GovWin API Credentials
###############################################################################

govwin_client_id     = "your-govwin-client-id"
govwin_client_secret = "your-govwin-client-secret"
govwin_username      = "your-govwin-email@company.com"
govwin_password      = "your-govwin-password"

###############################################################################
# Required - HubSpot Credentials
###############################################################################

hubspot_private_app_token = "pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

###############################################################################
# Optional - AWS Configuration
###############################################################################

# aws_profile = "default"             # AWS CLI profile name
# aws_region  = "us-east-1"
# environment = "prod"

###############################################################################
# Optional - Sync Configuration
###############################################################################

# sync_schedule          = "rate(1 hour)"    # How often the orchestrator runs
# govwin_opp_types       = "ALL"             # OPP, BID, TNS, FBO, OPN, TOP, ALL
# govwin_market          = ""                # Federal, SLED, or both (empty)
# initial_lookback_days  = 365               # Days to look back on first sync
# max_concurrency        = 2                 # Worker reservedConcurrency (GovWin 4k/hour budget gates this)
# batch_size             = 10                # Opportunities per SQS message

###############################################################################
# Optional - Opportunity Filtering (choose one or combine)
###############################################################################
# By default, only opportunities your BD team marks for "Web Services Download"
# in GovWin IQ are synced. Set govwin_marked_version = "" to disable and sync all.

# govwin_marked_version  = "2.2"             # "2.2" (Web Services), "2" (Deltek CRM), "" (disabled)
# govwin_saved_search_id = ""                # GovWin saved search ID (filter by search)
# govwin_bookmarked_only = false             # Only sync bookmarked opps

###############################################################################
# Optional - Notifications
###############################################################################

# enable_notifications = true
# notification_email   = "alerts@company.com"

###############################################################################
# Required - AWS Partner Central (ACE) submission half
###############################################################################

# Default ACE catalog. Keep as Sandbox for dev; flip to "AWS" only on prod.
# ace_catalog = "Sandbox"

# Default solution to associate with each opportunity. Discover via:
#   aws partnercentral-selling list-solutions --catalog AWS --region us-east-1
ace_default_solution_id = "S-1234567"

# ace_default_involvement_type = "Co-Sell"
# ace_default_visibility       = "Full"
# ace_trigger_stages           = "submit_to_aws,submitted_to_aws"

# Partner company legal name surfaced to AWS Partner Central as
# ExpectedCustomerSpend.TargetCompany. Set this per deployment to your
# company's legal name; the default is a placeholder that AWS will accept
# but is not what you want in production.
ace_partner_company_name = "Acme Cloud LLC"

###############################################################################
# Required - HubSpot developer-platform webhook app (2025.2+)
###############################################################################
# Created via `hs project create` + `hs project upload`. After upload, copy
# the appId and clientSecret from the HubSpot developer portal.

hubspot_webhook_app_id        = "12345678"
hubspot_webhook_client_secret = "client-secret-from-hubspot-app-settings"

###############################################################################
# Optional - Tags
###############################################################################

# tags = {
#   Team    = "Engineering"
#   Project = "GovWin Integration"
# }
