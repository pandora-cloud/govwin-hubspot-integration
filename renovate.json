{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard",
    "security:openssf-scorecard"
  ],
  "schedule": ["before 6am on monday"],
  "timezone": "America/New_York",
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on the first day of the month"]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "vulnerability"],
    "schedule": ["at any time"]
  },
  "packageRules": [
    {
      "description": "Auto-merge security patches without ceremony",
      "matchUpdateTypes": ["patch"],
      "matchPackagePatterns": ["*"],
      "vulnerabilityFixOnly": true,
      "automerge": true
    },
    {
      "description": "Group AWS provider + AWS-related Terraform updates together",
      "matchManagers": ["terraform"],
      "matchPackageNames": ["hashicorp/aws", "hashicorp/random"],
      "groupName": "terraform aws ecosystem"
    },
    {
      "description": "Group Python core libs",
      "matchManagers": ["pip_requirements", "pep621"],
      "matchPackageNames": ["pydantic", "httpx", "boto3", "tenacity", "python-dateutil"],
      "groupName": "python runtime deps"
    },
    {
      "description": "Group Python dev tooling",
      "matchManagers": ["pip_requirements", "pep621"],
      "matchPackageNames": ["ruff", "mypy", "pytest", "pytest-asyncio", "respx", "moto"],
      "groupName": "python dev tooling"
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    }
  ]
}
